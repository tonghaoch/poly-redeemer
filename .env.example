# Polymarket wallet private key (same as poly-sniper)
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Polygon RPC URL (same as poly-sniper)
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_KEY

# Proxy wallet address (required if you trade via Polymarket proxy wallet)
# Find it at: https://polygonscan.com — check your EOA's recent transactions,
# the proxy wallet is the Gnosis Safe address that executes your trades.
PROXY_WALLET_ADDRESS=0x_your_proxy_wallet_address_here
